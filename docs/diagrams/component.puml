@startuml component
' Diagrama de Componentes — Sistema de Moeda Estudantil (Lab03S01)
' Fonte: plan.md (estrutura MVC), contracts/api-overview.md (superfície HTTP)
' Frontend Thymeleaf server-rendered (Lab03S02): comunicação Cliente↔Controlador
' usa HTTP+HTML (form-encoded), não JSON.

skinparam shadowing false
skinparam componentStyle rectangle
title Diagrama de Componentes — Sistema de Moeda Estudantil

actor "Aluno / Professor /\nEmpresa Parceira" as Usuario

node "Navegador" {
  [Cliente Web\n(Thymeleaf, pt-BR)] as ClienteWeb
}

package "Aplicação Micronaut (Java 21)" {

  package "Controladores (MVC: C)" {
    [ControleAutenticacao]
    [ControleAluno]
    [ControleProfessor]
    [ControleEmpresaParceira]
    [ControleVantagem]
    [ControleTransacao]
    [ControleExtrato]
  }

  package "Serviços" {
    [ServicoAutenticacao]
    [ServicoCadastro]
    [ServicoTransferencia]
    [ServicoResgate]
    [ServicoExtrato]
    [ServicoNotificacao]
  }

  package "DAOs (Padrão DAO via Micronaut Data JPA)" {
    [AlunoDAO]
    [ProfessorDAO]
    [EmpresaParceiraDAO]
    [InstituicaoDAO]
    [VantagemDAO]
    [TransacaoDAO]
    [CredencialDAO]
  }

  package "Modelos (MVC: M)" {
    [Usuario] as MUsuario
    [Aluno] as MAluno
    [Professor] as MProfessor
    [Instituicao] as MInstituicao
    [EmpresaParceira] as MEmpresa
    [Vantagem] as MVantagem
    [Transacao] as MTransacao
    [Notificacao] as MNotificacao
    [Credencial] as MCredencial
  }

}

database "Banco H2 (file mode)\n(Lab03S02)" as BD
cloud "Provedor de E-mail\n(SMTP — Lab03S03)" as Email

' === Interfaces fornecidas (lollipop) e requeridas (socket) ===

' IApiHttp — exposta pela camada de Controladores, consumida pelo Cliente Web
interface "IApiHttp"        as IApiHttp
ControleAutenticacao    -up- IApiHttp
ControleAluno           -up- IApiHttp
ControleProfessor       -up- IApiHttp
ControleEmpresaParceira -up- IApiHttp
ControleVantagem        -up- IApiHttp
ControleTransacao       -up- IApiHttp
ControleExtrato         -up- IApiHttp
ClienteWeb              )-- IApiHttp : "HTTP+HTML\n(form-encoded)"

' Interfaces de serviço (uma por serviço) — fornecidas pelos serviços, requeridas pelos controladores
interface "IServicoAuth"        as ISvcAuth
interface "IServicoCadastro"    as ISvcCad
interface "IServicoTransfer"    as ISvcTrf
interface "IServicoResgate"     as ISvcRsg
interface "IServicoExtrato"     as ISvcExt
interface "IServicoNotif"       as ISvcNot

ServicoAutenticacao  -up- ISvcAuth
ServicoCadastro      -up- ISvcCad
ServicoTransferencia -up- ISvcTrf
ServicoResgate       -up- ISvcRsg
ServicoExtrato       -up- ISvcExt
ServicoNotificacao   -up- ISvcNot

ControleAutenticacao    )-- ISvcAuth : Java\n(in-process)
ControleAluno           )-- ISvcCad  : Java\n(in-process)
ControleEmpresaParceira )-- ISvcCad
ControleVantagem        )-- ISvcCad
ControleTransacao       )-- ISvcTrf
ControleTransacao       )-- ISvcRsg
ControleExtrato         )-- ISvcExt

' Serviço → Serviço (notificação acionada por transferências/resgates)
ServicoTransferencia    )-- ISvcNot : "notifica aluno"
ServicoResgate          )-- ISvcNot : "envia cupom +\nconfirmação"

' IRepositorio — interface única fornecida por todos os DAOs, requerida pelos serviços
interface "IRepositorio<T>" as IRepo

AlunoDAO            -up- IRepo
ProfessorDAO        -up- IRepo
EmpresaParceiraDAO  -up- IRepo
InstituicaoDAO      -up- IRepo
VantagemDAO         -up- IRepo
TransacaoDAO        -up- IRepo
CredencialDAO       -up- IRepo

ServicoAutenticacao  )-- IRepo : Java\n(in-process)
ServicoCadastro      )-- IRepo
ServicoTransferencia )-- IRepo
ServicoResgate       )-- IRepo
ServicoExtrato       )-- IRepo

' IBanco (JDBC) — fornecida pelo banco, requerida pelos DAOs
interface "IBanco (JDBC)" as IBanco
BD -up- IBanco
AlunoDAO           )-- IBanco : "JDBC/TCP"
ProfessorDAO       )-- IBanco
EmpresaParceiraDAO )-- IBanco
InstituicaoDAO     )-- IBanco
VantagemDAO        )-- IBanco
TransacaoDAO       )-- IBanco
CredencialDAO      )-- IBanco

' IEmail (SMTP) — fornecida pelo provedor externo, requerida pelo ServicoNotificacao
interface "IEmail (SMTP)" as IEmail
Email -up- IEmail
ServicoNotificacao )-- IEmail : "SMTP/TCP"

' === Pareamento DAO ↔ Modelo (omitido visualmente; é trivial pelos nomes) ===
' AlunoDAO ↔ Aluno, ProfessorDAO ↔ Professor, etc.

note right of ServicoNotificacao
  Provedor SMTP concreto (SendGrid,
  Mailgun, SMTP nativo) decidido em
  Lab03S03. Em Lab03S02 o serviço
  apenas registra Notificacao no banco.
end note

note bottom of BD
  H2 em modo arquivo (jdbc:h2:./data/...)
  Migrations versionadas via Flyway.
  Schema reflete herança JPA JOINED
  da hierarquia Usuario.
end note

note top of IApiHttp
  Comunicação Cliente↔Controlador é
  HTTP+HTML form-encoded (Thymeleaf
  server-rendered). Não há REST/JSON
  no escopo do Lab03S02.
end note

note top of IRepo
  Implementada via Micronaut Data JPA.
  Cada DAO estende CrudRepository<T,Long>;
  o nome "DAO" preserva o vocabulário do
  Padrão DAO exigido pelo enunciado.
end note

@enduml
