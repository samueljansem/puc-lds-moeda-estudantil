@startuml component
' Diagrama de Componentes — Sistema de Moeda Estudantil (Lab03S03 final)
' Reflete a arquitetura MVC implementada: navegador Thymeleaf →
' controllers Micronaut → serviços → DAOs (Micronaut Data JPA) → H2.
' Notificação é interna (outbox em tabela), sem SMTP externo.

skinparam shadowing false
skinparam componentStyle rectangle
title Diagrama de Componentes — Sistema de Moeda Estudantil

actor "Aluno / Professor /\nEmpresa / Admin" as Usuario

node "Navegador" {
  [Cliente Web\n(HTML + Thymeleaf, pt-BR)] as ClienteWeb
}

package "Aplicação Micronaut (Java 21)" {

  package "Controladores (MVC: C)" {
    [LoginController]
    [LogoutController]
    [HomeController]
    [AlunoController]
    [ProfessorController]
    [EmpresaParceiraController]
    [VantagemController]
    [CatalogoController]
    [FotoVantagemController]
    [NotificacaoController]
    [AdminController]
    [TrocaSenhaController]
    [RecuperacaoSenhaController]
  }

  package "Serviços" {
    [ServicoAutenticacao]
    [ServicoCadastro]
    [ServicoMoeda]
    [ServicoVantagem]
    [ServicoResgate]
    [ServicoSemestre]
    [ServicoNotificacao]
    [ServicoRecuperacaoSenha]
  }

  package "DAOs (Padrão DAO via Micronaut Data JPA)" {
    [AlunoDAO]
    [ProfessorDAO]
    [EmpresaParceiraDAO]
    [UsuarioDAO]
    [InstituicaoDAO]
    [VantagemDAO]
    [TransferenciaMoedaDAO]
    [ResgateDAO]
    [NotificacaoDAO]
    [TokenRecuperacaoDAO]
    [CredencialDAO]
  }

  package "Views (MVC: V — Thymeleaf)" {
    [Templates HTML\n(layout, aluno-*, empresa-*,\nprofessor-*, admin-*, etc.)] as Views
  }

}

database "Banco H2 (file mode)\n./data/moedaestudantil.mv.db" as BD

' === IApiHttp — fornecida pelos controladores, requerida pelo Cliente Web ===
interface "IApiHttp"        as IApiHttp
LoginController              -up- IApiHttp
LogoutController             -up- IApiHttp
HomeController               -up- IApiHttp
AlunoController              -up- IApiHttp
ProfessorController          -up- IApiHttp
EmpresaParceiraController    -up- IApiHttp
VantagemController           -up- IApiHttp
CatalogoController           -up- IApiHttp
FotoVantagemController       -up- IApiHttp
NotificacaoController        -up- IApiHttp
AdminController              -up- IApiHttp
TrocaSenhaController         -up- IApiHttp
RecuperacaoSenhaController   -up- IApiHttp

ClienteWeb )-- IApiHttp : "HTTP+HTML\n(form-encoded / multipart)"
Usuario --> ClienteWeb

' === Interfaces de serviço — fornecidas pelos serviços ===
interface "IAuth"      as ISvcAuth
interface "ICadastro"  as ISvcCad
interface "IMoeda"     as ISvcMoeda
interface "IVantagem"  as ISvcVant
interface "IResgate"   as ISvcRsg
interface "ISemestre"  as ISvcSem
interface "INotif"     as ISvcNot
interface "IRecSenha"  as ISvcRec

ServicoAutenticacao         -up- ISvcAuth
ServicoCadastro             -up- ISvcCad
ServicoMoeda                -up- ISvcMoeda
ServicoVantagem             -up- ISvcVant
ServicoResgate              -up- ISvcRsg
ServicoSemestre             -up- ISvcSem
ServicoNotificacao          -up- ISvcNot
ServicoRecuperacaoSenha     -up- ISvcRec

' Controladores → Serviços (Java in-process)
LoginController            )-- ISvcAuth
AlunoController            )-- ISvcCad
EmpresaParceiraController  )-- ISvcCad
ProfessorController        )-- ISvcMoeda
ProfessorController        )-- ISvcCad
VantagemController         )-- ISvcVant
CatalogoController         )-- ISvcRsg
CatalogoController         )-- ISvcVant
AdminController            )-- ISvcSem
TrocaSenhaController       )-- ISvcCad
RecuperacaoSenhaController )-- ISvcRec

' Serviços → Serviço de notificação (outbox)
ServicoMoeda             )-- ISvcNot : "notifica aluno"
ServicoResgate           )-- ISvcNot : "cupom + confirmação"
ServicoRecuperacaoSenha  )-- ISvcNot : "link reset"

' === IRepositorio — fornecida por todos os DAOs ===
interface "IRepositorio<T>" as IRepo

AlunoDAO              -up- IRepo
ProfessorDAO          -up- IRepo
EmpresaParceiraDAO    -up- IRepo
UsuarioDAO            -up- IRepo
InstituicaoDAO        -up- IRepo
VantagemDAO           -up- IRepo
TransferenciaMoedaDAO -up- IRepo
ResgateDAO            -up- IRepo
NotificacaoDAO        -up- IRepo
TokenRecuperacaoDAO   -up- IRepo
CredencialDAO         -up- IRepo

ServicoAutenticacao         )-- IRepo
ServicoCadastro             )-- IRepo
ServicoMoeda                )-- IRepo
ServicoVantagem             )-- IRepo
ServicoResgate              )-- IRepo
ServicoSemestre             )-- IRepo
ServicoNotificacao          )-- IRepo
ServicoRecuperacaoSenha     )-- IRepo

' Controladores que leem DAO diretamente
NotificacaoController  )-- IRepo
FotoVantagemController )-- IRepo
AdminController        )-- IRepo

' === IBanco (JDBC) — fornecida pelo H2, requerida pelos DAOs ===
interface "IBanco (JDBC)" as IBanco
BD -up- IBanco
AlunoDAO              )-- IBanco : "JDBC/TCP\n(in-process)"
ProfessorDAO          )-- IBanco
EmpresaParceiraDAO    )-- IBanco
UsuarioDAO            )-- IBanco
InstituicaoDAO        )-- IBanco
VantagemDAO           )-- IBanco
TransferenciaMoedaDAO )-- IBanco
ResgateDAO            )-- IBanco
NotificacaoDAO        )-- IBanco
TokenRecuperacaoDAO   )-- IBanco
CredencialDAO         )-- IBanco

' Controllers → Views (template engine acionado pelo Micronaut)
LoginController              .-> Views
HomeController               .-> Views
AlunoController              .-> Views
ProfessorController          .-> Views
EmpresaParceiraController    .-> Views
VantagemController           .-> Views
CatalogoController           .-> Views
NotificacaoController        .-> Views
AdminController              .-> Views
TrocaSenhaController         .-> Views
RecuperacaoSenhaController   .-> Views

note top of IApiHttp
  HTTP + HTML — server-rendered.
  Sem REST/JSON. Forms application/
  x-www-form-urlencoded; upload de
  foto via multipart/form-data.
end note

note right of ServicoNotificacao
  Outbox interno: persiste cada
  "envio" como linha em `notificacao`.
  Sem SMTP externo (decisão de Fase 2
  para simplificar demo).
  US12 (falha de entrega) seria
  modelada com status=FALHA.
end note

note bottom of BD
  H2 em modo arquivo:
  `jdbc:h2:./data/moedaestudantil`.
  Migrations versionadas via Flyway
  (V1 schema → V5 seed Lab03S03).
end note

note top of IRepo
  Implementada via Micronaut Data JPA.
  Cada DAO estende CrudRepository<T,Long>;
  o nome "DAO" preserva o vocabulário do
  Padrão DAO exigido pelo enunciado.
end note

@enduml
